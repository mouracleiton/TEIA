  "pet": {
    "nome": "Protocolo de Execução TEIA",
    "descricao": "Sistema operacional prático que transforma a matriz teórica em inteligência acionável",
    "fases": [
      {
        "fase": 1,
        "nome": "Delimitação do Fenômeno",
        "objetivo": "Nomear o alvo e aplicar 3-5 dimensões de superfície",
        "output": "Ficha de fenômeno com dimensões preliminares"
      },
      {
        "fase": 2,
        "nome": "Triagem Óptica",
        "objetivo": "Escolher 2-3 lentes analíticas que rasgam o óbvio",
        "output": "Seleção de lentes com justificativa"
      },
      {
        "fase": 3,
        "nome": "Mergulho no Abismo",
        "objetivo": "Buscar dimensões invisíveis (níveis 3-18) que sustentam o fenômeno",
        "output": "Mapa de dimensões profundas conectadas"
      },
      {
        "fase": 4,
        "nome": "Mapeamento de Loops",
        "objetivo": "Conectar dimensões em cadeia causal e identificar pontos de alavanca",
        "output": "Diagrama de loop causal (CLD) com pontos de alavanca"
      },
      {
        "fase": 5,
        "nome": "Síntese Disjuntiva",
        "objetivo": "Diagnosticar a máquina que produz o problema e apontar nós críticos",
        "output": "Documento TEIA protocolado com recomendação de ação"
      }
    ]
  },
